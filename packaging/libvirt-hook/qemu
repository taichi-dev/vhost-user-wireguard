#!/bin/bash
# SPDX-License-Identifier: MIT OR Apache-2.0
#
# Reference dispatcher for /etc/libvirt/hooks/qemu.
#
# libvirt invokes a single hook file at /etc/libvirt/hooks/qemu. This
# dispatcher then runs every executable in /etc/libvirt/hooks/qemu.d/ in
# turn, replaying the domain XML (sent by libvirt on stdin) to each one,
# so multiple tools can coexist instead of fighting over the single qemu
# file. This pattern mirrors VFIO-Tools and similar projects.
#
# Install (ONLY if you have no existing /etc/libvirt/hooks/qemu):
#     sudo install -m 0755 packaging/libvirt-hook/qemu /etc/libvirt/hooks/qemu
#     sudo systemctl restart libvirtd
#
# If you ALREADY have an /etc/libvirt/hooks/qemu, do NOT overwrite it.
# Either migrate to this dispatcher pattern manually, or invoke our drop-in
# directly from your existing hook with the same args + stdin XML.

set -euo pipefail

HOOK_DIR="/etc/libvirt/hooks/qemu.d"
[ -d "$HOOK_DIR" ] || exit 0

# libvirt sends the domain XML on stdin. Read it once so we can hand the
# same bytes to every drop-in.
if [ -t 0 ]; then
    XML=""
else
    XML=$(cat)
fi

for hook in "$HOOK_DIR"/*; do
    [ -f "$hook" ] || continue
    [ -x "$hook" ] || continue
    case "$(basename -- "$hook")" in
        .*|*.bak|*.dpkg-*|*.rpm-*|*.rpmsave|*.rpmnew|*~) continue ;;
    esac
    "$hook" "$@" <<<"$XML"
done
